# ============================================================
# Environment Configuration Template
# Copy this file to server/.env for backend configuration
# Copy this file to .env.development for Vite frontend config
# NEVER commit the actual .env files to version control
# ============================================================

# -----------------------------------------------------------
# VITE (Frontend) — read by Vite at build time
# -----------------------------------------------------------

# Development: http://localhost:3001
# Production:  https://programing.hetdubai.com/api (proxied via Apache)
VITE_API_URL=http://localhost:3001

VITE_API_TIMEOUT=30000
VITE_LOG_LEVEL=INFO
VITE_APP_DOMAIN=https://programing.hetdubai.com

# -----------------------------------------------------------
# SERVER (Backend) — read by Node.js at runtime
# -----------------------------------------------------------

NODE_ENV=development
API_PORT=3001

# Comma-separated allowed CORS origins
# Development: http://localhost:5173
# Production:  https://programing.hetdubai.com
CORS_ORIGINS=http://localhost:5173

# JWT Secrets — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Use DIFFERENT values for production vs development
JWT_ACCESS_SECRET=replace_me_access_secret_32_bytes
JWT_REFRESH_SECRET=replace_me_refresh_secret_32_bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# -----------------------------------------------------------
# GAS / Cloudflare Worker
# -----------------------------------------------------------

# Cloudflare Worker proxy URL (recommended — hides real GAS URLs)
GAS_PROXY_URL=https://het-gas-proxy.hetgraphic17.workers.dev/gas
GAS_PROXY_AUTH_TOKEN=replace_me_proxy_token

# Direct GAS fallback URLs (used if Worker is unreachable)
# These are the Google Apps Script web app exec URLs
GAS_BRIDGE_URL_MEN_MATERIAL=https://script.google.com/macros/s/<MEN_DEPLOYMENT_ID>/exec
GAS_BRIDGE_URL_LACE_GAYLE=https://script.google.com/macros/s/<LACE_DEPLOYMENT_ID>/exec

# GAS auth tokens (passed as ?token= to GAS; stored as Worker secrets in production)
GAS_SECRET_KEY_MEN_MATERIAL=replace_me_men_token
GAS_SECRET_KEY_LACE_GAYLE=replace_me_lace_token

# -----------------------------------------------------------
# Cache
# -----------------------------------------------------------

# GAS response cache TTL in milliseconds (30000 = 30 seconds)
API_CACHE_TTL_MS=30000
