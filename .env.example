# ============================================================
# Environment Configuration Template
# Use this file as a reference for both frontend (.env.development/.env.production)
# and backend (server/.env) variable names.
# NEVER commit real secrets.
# ============================================================

# -----------------------------------------------------------
# VITE (Frontend) — read by Vite at build time
# -----------------------------------------------------------

# Development: http://localhost:3001
# Production:  https://programing.hetdubai.com/api (or dedicated API domain)
VITE_API_URL=http://localhost:3001
VITE_APP_TITLE=het Programming Database
VITE_ENABLE_DEBUG=false

# -----------------------------------------------------------
# SERVER (Backend) — read by Node.js at runtime
# -----------------------------------------------------------

NODE_ENV=development
API_PORT=3001

# Comma-separated allowed CORS origins
# Development: http://localhost:5173
# Production:  https://programing.hetdubai.com
CORS_ORIGINS=http://localhost:5173

# Optional one-time bootstrap admin for first startup only.
# Remove both values after the first admin is created.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# JWT Secrets — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_access_secret_32_bytes
JWT_REFRESH_SECRET=replace_me_refresh_secret_32_bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# -----------------------------------------------------------
# GAS / Cloudflare Worker
# -----------------------------------------------------------

# Optional generic fallback keys used by split keys below when not set.
GAS_BRIDGE_URL=
GAS_SECRET_KEY=

# Direct Google Apps Script endpoints (recommended explicit split)
GAS_BRIDGE_URL_MEN_MATERIAL=https://script.google.com/macros/s/<MEN_DEPLOYMENT_ID>/exec
GAS_BRIDGE_URL_LACE_GAYLE=https://script.google.com/macros/s/<LACE_DEPLOYMENT_ID>/exec

# GAS tokens (passed to GAS by backend/worker)
GAS_SECRET_KEY_MEN_MATERIAL=replace_me_men_token
GAS_SECRET_KEY_LACE_GAYLE=replace_me_lace_token

# Optional referrer validation
GAS_ALLOWED_REFERRER=https://programing.hetdubai.com

# Worker proxy (recommended in production)
GAS_PROXY_URL=
GAS_PROXY_AUTH_TOKEN=

# -----------------------------------------------------------
# Performance / Resilience
# -----------------------------------------------------------

API_CACHE_TTL_MS=60000
GAS_RETRY_MAX_ATTEMPTS=3
GAS_RETRY_BASE_DELAY_MS=300
GAS_RETRY_MAX_DELAY_MS=4000
GAS_REQUEST_CONCURRENCY=6
GAS_RETRY_STATUS_CODES=429,500,502,503,504

# -----------------------------------------------------------
# Web Push Notifications (VAPID)
# -----------------------------------------------------------

WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:ops@your-domain.com

# -----------------------------------------------------------
# Monitoring Alerts Delivery
# -----------------------------------------------------------

TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

EMAIL_ALERTS_ENABLED=false
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=
