{
  "name": "programming-database",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "gas:login": "clasp login --no-localhost",
    "gas:clone": "clasp clone",
    "gas:clone:lace": "clasp clone 1yzo7jChly3Er-LDECdyvvMdYC6-nQLuQMMXp2xXwRaG2H2xiLYkisL0L",
    "gas:clone:men": "clasp clone 1U2nqRQZxDxmnajTy1vfSyRbX5esE72XNC795BhFtniZh600rLDgadXwn",
    "gas:pull": "clasp pull",
    "gas:push": "clasp push",
    "gas:deploy": "clasp deploy",
    "gas:deploy:create": "clasp deploy --description \"Automated deploy\"",
    "gas:deploy:list": "clasp deployments",
    "gas:version": "clasp version",
    "gas:check:entrypoints": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-ChildItem -Recurse -File | Select-String -Pattern 'function doGet\\(|function doPost\\(|function APP_saveEntry\\(' | ForEach-Object { '{0}:{1}:{2}' -f $_.Path, $_.LineNumber, $_.Line.Trim() }\"",
    "gas:check:script-run": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-ChildItem -Recurse -File | Select-String -Pattern 'google\\.script\\.run' | ForEach-Object { '{0}:{1}:{2}' -f $_.Path, $_.LineNumber, $_.Line.Trim() }\"",
    "test:save-entry:dry-run": "node server/scripts/saveEntryDryRun.mjs",
    "worker:dev": "wrangler dev --config cloudflare-worker/wrangler.toml",
    "worker:deploy": "wrangler deploy --config cloudflare-worker/wrangler.toml"
  },
