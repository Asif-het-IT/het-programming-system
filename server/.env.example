# Express Middleware API
NODE_ENV=development
API_PORT=3001
CORS_ORIGINS=http://localhost:5174

# Optional one-time bootstrap admin for first startup only.
# Remove both values after the admin account has been created.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# JWT
JWT_ACCESS_SECRET=replace_me_access
JWT_REFRESH_SECRET=replace_me_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# GAS Bridge Security
GAS_BRIDGE_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
GAS_BRIDGE_URL_LACE_GAYLE=https://script.google.com/macros/s/YOUR_LACE_GAYLE_DEPLOYMENT_ID/exec
GAS_BRIDGE_URL_MEN_MATERIAL=https://script.google.com/macros/s/YOUR_MEN_MATERIAL_DEPLOYMENT_ID/exec
GAS_SECRET_KEY=replace_me_shared_secret
GAS_SECRET_KEY_LACE_GAYLE=replace_me_lace_secret
GAS_SECRET_KEY_MEN_MATERIAL=replace_me_men_secret
GAS_ALLOWED_REFERRER=https://your-frontend-domain.com

# Optional Cloudflare Worker token-shield proxy
GAS_PROXY_URL=
GAS_PROXY_AUTH_TOKEN=

# Performance
API_CACHE_TTL_MS=60000
